<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- 🔙 GERİ BUTONU -->
    <TextView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="←"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- 🔴 HAMLE -->
    <TextView
        android:id="@+id/tvMoveCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hamle: 20"
        android:textSize="24sp"
        android:textColor="#D32F2F"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 🟢 KELİME SAYISI -->
    <TextView
        android:id="@+id/tvAvailableWords"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gridde Oluşturulabilir Kelime Sayısı: 0"
        android:textSize="14sp"
        android:textColor="#388E3C"
        android:textStyle="bold|italic"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvMoveCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 🟦 GRID -->
    <GridLayout
        android:id="@+id/gridLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:rowCount="6"
        android:columnCount="6"
        android:padding="8dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toBottomOf="@id/tvAvailableWords"
        app:layout_constraintBottom_toTopOf="@id/tvScore"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 🔵 SKOR -->
    <TextView
        android:id="@+id/tvScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Skor: 0"
        android:textSize="24sp"
        android:textColor="#1976D2"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/tvFoundWordsTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 🆕 BULUNAN KELİMELER -->
    <TextView
        android:id="@+id/tvFoundWordsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bulunan Kelimeler"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="#000"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvScore"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:id="@+id/scrollFoundWords"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvFoundWordsTitle"
        app:layout_constraintBottom_toTopOf="@id/jokerBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvFoundWords"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#333"
            android:textSize="14sp"
            android:padding="8dp"/>
    </ScrollView>

    <!-- 🟡 JOKER BAR -->
    <LinearLayout
        android:id="@+id/jokerBar"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#EEEEEE"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 🐟 FISH -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">

                <ImageView
                    android:id="@+id/imgFish"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_fish"/>

                <TextView
                    android:id="@+id/btnFishInfo"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:text="?"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:textColor="#FFF"
                    android:background="#AA000000"
                    android:layout_gravity="top|end"/>
            </FrameLayout>

            <TextView
                android:id="@+id/txtFishCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"/>
        </LinearLayout>

        <!-- 🎯 WHEEL -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">

                <ImageView
                    android:id="@+id/imgWheel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_wheel"/>

                <TextView
                    android:id="@+id/btnWheelInfo"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:text="?"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:textColor="#FFF"
                    android:background="#AA000000"
                    android:layout_gravity="top|end"/>
            </FrameLayout>

            <TextView
                android:id="@+id/txtWheelCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"/>
        </LinearLayout>

        <!-- 🍭 LOLLIPOP -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">

                <ImageView
                    android:id="@+id/imgLollipop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_lollipop"/>

                <TextView
                    android:id="@+id/btnLollipopInfo"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:text="?"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:textColor="#FFF"
                    android:background="#AA000000"
                    android:layout_gravity="top|end"/>
            </FrameLayout>

            <TextView
                android:id="@+id/txtLollipopCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"/>
        </LinearLayout>

        <!-- 🔄 SWAP -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">

                <ImageView
                    android:id="@+id/imgSwap"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_swap"/>

                <TextView
                    android:id="@+id/btnSwapInfo"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:text="?"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:textColor="#FFF"
                    android:background="#AA000000"
                    android:layout_gravity="top|end"/>
            </FrameLayout>

            <TextView
                android:id="@+id/txtSwapCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"/>
        </LinearLayout>

        <!-- 🔀 SHUFFLE -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">

                <ImageView
                    android:id="@+id/imgShuffle"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_shuffle"/>

                <TextView
                    android:id="@+id/btnShuffleInfo"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:text="?"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:textColor="#FFF"
                    android:background="#AA000000"
                    android:layout_gravity="top|end"/>
            </FrameLayout>

            <TextView
                android:id="@+id/txtShuffleCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"/>
        </LinearLayout>

        <!-- 🎉 PARTY -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">

                <ImageView
                    android:id="@+id/imgParty"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_party"/>

                <TextView
                    android:id="@+id/btnPartyInfo"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:text="?"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:textColor="#FFF"
                    android:background="#AA000000"
                    android:layout_gravity="top|end"/>
            </FrameLayout>

            <TextView
                android:id="@+id/txtPartyCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>